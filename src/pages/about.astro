---
import Layout from "../layouts/main.astro";
---

<Layout title="About">
  <section class="relative z-20 max-w-2xl mx-auto my-16 px-7 lg:px-0">
    <h1 class="text-3xl font-bold text-neutral-900 dark:text-white">About</h1>
    <p class="mt-3 text-neutral-700 dark:text-neutral-300">
      This site is now a single-page homepage. Please use the About section on the home page.
    </p>
    <a href="/#about" class="mt-4 inline-block underline decoration-dotted text-neutral-800 dark:text-neutral-200">Go to About section</a>
  </section>
</Layout>
