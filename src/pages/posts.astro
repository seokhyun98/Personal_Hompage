---
import Layout from "../layouts/main.astro";
---

<Layout title="Publications">
  <section class="relative z-20 max-w-2xl mx-auto my-16 px-7 lg:px-0">
    <h1 class="text-3xl font-bold text-neutral-900 dark:text-white">Publications</h1>
    <p class="mt-3 text-neutral-700 dark:text-neutral-300">
      Publications are now integrated into the first page with tag filtering.
    </p>
    <a href="/#publications" class="mt-4 inline-block underline decoration-dotted text-neutral-800 dark:text-neutral-200">Go to Publications section</a>
  </section>
</Layout>
