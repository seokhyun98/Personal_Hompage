---
import Layout from "../layouts/main.astro";

const description = "Fun Projects by Seokhyun Hwang - In-car XR systems, piano accompaniment robot, kiwi pollination drone, and vision-based table tennis system.";
---

<Layout title="Projects - Seokhyun Hwang" description={description} robots="noindex, follow">
  <section class="relative z-20 max-w-2xl mx-auto my-16 px-7 lg:px-0">
    <h1 class="text-3xl font-bold text-neutral-900 dark:text-white">Projects</h1>
    <p class="mt-3 text-neutral-700 dark:text-neutral-300">
      Fun Projects are now shown directly on the first page.
    </p>
    <a href="/#projects" class="mt-4 inline-block underline decoration-dotted text-neutral-800 dark:text-neutral-200">Go to Fun Projects section</a>
  </section>
</Layout>
