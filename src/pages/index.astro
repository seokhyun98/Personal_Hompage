---
import AboutSection from "../components/sections/about-section.astro";
import ExtrasSection from "../components/sections/extras-section.astro";
import FunProjectsSection from "../components/sections/fun-projects-section.astro";
import HeroSection from "../components/sections/hero-section.astro";
import PublicationsSection from "../components/sections/publications-section.astro";
import ResearchGoalsSection from "../components/sections/research-goals-section.astro";
import about from "../collections/about.json";
import Layout from "../layouts/main.astro";

const siteUrl = "https://www.seokhyunhwang.com";

const personLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: about.name,
	alternateName: "Seokhyun Shawn Hwang",
	url: siteUrl,
	image: `${siteUrl}/images/profile/profile.jpg`,
	jobTitle: "Ph.D. Student, Information Science",
	email: `mailto:${about.email}`,
	worksFor: {
		"@type": "Organization",
		name: "University of Washington",
		url: "https://www.washington.edu/",
	},
	affiliation: {
		"@type": "Organization",
		name: "University of Washington",
	},
	sameAs: about.socialLinks.map((item) => item.url),
};

const websiteLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Seokhyun Hwang",
	url: siteUrl,
	description:
		"Ph.D. Student in Information Science at University of Washington. Research in HCI, VR/AR, haptics, and wearable systems.",
	author: { "@type": "Person", name: about.name, url: siteUrl },
};
---

<Layout title="Seokhyun Hwang - Ph.D. Student in HCI, VR/AR, Haptics">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
  <HeroSection />
  <ResearchGoalsSection />
  <PublicationsSection />
  <AboutSection />
  <ExtrasSection />
  <FunProjectsSection />
</Layout>
