---
import AboutSection from "../components/sections/about-section.astro";
import ExtrasSection from "../components/sections/extras-section.astro";
import FunProjectsSection from "../components/sections/fun-projects-section.astro";
import HeroSection from "../components/sections/hero-section.astro";
import PublicationsSection from "../components/sections/publications-section.astro";
import ResearchGoalsSection from "../components/sections/research-goals-section.astro";
import Layout from "../layouts/main.astro";

const homeDescription =
	"Seokhyun (Shawn) Hwang is a Ph.D. student in Information Science at the University of Washington. Explore his publications, awards, talks, and profiles including Google Scholar and ACM DL.";
const homeKeywords = [
	"Seokhyun Hwang",
	"Shawn Hwang",
	"Google Scholar",
	"ACM DL",
	"HCI",
	"VR AR research",
	"haptics",
	"wearable systems",
];
---

<Layout
  title="Seokhyun Hwang - Ph.D. Student in HCI, VR/AR, Haptics"
  description={homeDescription}
  keywords={homeKeywords}
>
  <HeroSection />
  <ResearchGoalsSection />
  <PublicationsSection />
  <AboutSection />
  <ExtrasSection />
  <FunProjectsSection />
</Layout>
