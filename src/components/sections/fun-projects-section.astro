---
import funProjects from "../../collections/fun-projects.json";
---

<section id="projects" class="relative z-20 w-full max-w-5xl mx-auto mt-14 mb-16 px-7 xl:px-0">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">Fun Projects</h2>
  <p class="mt-3 rounded-md bg-neutral-100 px-3 py-2 text-sm text-neutral-700 dark:bg-neutral-900 dark:text-neutral-300">
    The project list below provides brief descriptions of personal projects unrelated to publication.
  </p>
  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      funProjects.map((project) => (
        <article class="group relative overflow-hidden rounded-lg border border-dashed border-neutral-300 dark:border-neutral-700">
          <img
            src={project.image}
            alt={project.title}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover aspect-video"
          />
          <div class="fun-project-overlay absolute inset-0 overflow-y-auto bg-black/55 p-4 opacity-0 transition-opacity group-hover:opacity-100">
            <h3 class="text-sm font-semibold text-white">{project.title}</h3>
            <p class="mt-2 text-xs leading-5 text-white/90">{project.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .fun-project-overlay {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.4) transparent;
  }
  .fun-project-overlay::-webkit-scrollbar {
    width: 6px;
  }
  .fun-project-overlay::-webkit-scrollbar-track {
    background: transparent;
  }
  .fun-project-overlay::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.4);
    border-radius: 3px;
  }
  .fun-project-overlay::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.6);
  }
</style>
