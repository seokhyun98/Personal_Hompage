---
import researchLayersData from "../../collections/research-layers.json";

const layers = researchLayersData.layers;
const layerById = Object.fromEntries(layers.map((layer) => [layer.id, layer]));
const connections = researchLayersData.connections.map((connection, idx) => ({
  ...connection,
  id: `conn-${idx}`,
  label: (connection as { label?: string }).label ?? connection.elements.join(", "),
}));

const connectionLayouts = {
  "sensory-motor": { path: "M302 66 L318 66", labelX: 310, labelY: 54 },
  "motor-sensory": { path: "M318 86 L302 86", labelX: 310, labelY: 104 },
  "sensory-behavior": { path: "M187 132 L120 132 L120 158 L187 158", labelX: 76, labelY: 148 },
  "behavior-sensory": { path: "M170 158 L92 158 L92 116 L170 116", labelX: 48, labelY: 126 },
  "motor-behavior": { path: "M433 132 L500 132 L500 158 L433 158", labelX: 544, labelY: 148 },
  "behavior-motor": { path: "M450 158 L528 158 L528 116 L450 116", labelX: 572, labelY: 126 },
};
---

<section id="research-goals" class="relative z-20 mx-auto mt-12 w-full max-w-5xl px-7 xl:px-0">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">Research Goals</h2>
  <p class="mt-2 text-base font-semibold text-neutral-800 dark:text-neutral-200">{researchLayersData.thesis}</p>

  <div class="problem-approach mt-4 rounded-lg border border-dashed border-neutral-300 p-4 dark:border-neutral-600">
    <h3 class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">Problem & Approach</h3>
    <p class="sidebar-label mt-2">Problem</p>
    <p class="sidebar-text">{researchLayersData.problemStatement}</p>
    <p class="sidebar-label mt-4">Our Approach</p>
    <p class="sidebar-text">{researchLayersData.approachStatement}</p>
  </div>

  <div class="research-infographic mt-5" data-active-layer="">
    <div class="research-stage">
      <div class="diagram-shell">
        <div class="diagram-canvas">
          <svg class="connection-svg" viewBox="0 0 620 360" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <marker id="arrow-sensory" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 8 3, 0 6" fill="rgb(217 119 6)" />
              </marker>
              <marker id="arrow-motor" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 8 3, 0 6" fill="rgb(14 165 233)" />
              </marker>
              <marker id="arrow-behavior" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 8 3, 0 6" fill="rgb(139 92 246)" />
              </marker>
            </defs>
            {
              connections.map((connection) => {
                const key = `${connection.from}-${connection.to}`;
                const layout = connectionLayouts[key];
                if (!layout) return null;
                return (
                  <g class="connection" data-from={connection.from} data-to={connection.to}>
                    <path
                      d={layout.path}
                      class={`flow-path flow-${connection.from}`}
                      marker-end={`url(#arrow-${connection.from})`}
                    />
                    <text x={layout.labelX} y={layout.labelY} class="flow-label">
                      {connection.label}
                    </text>
                  </g>
                );
              })
            }
          </svg>

          <div class="cards-grid">
            <button type="button" class="layer-card card-sensory" data-layer-btn data-layer-id="sensory" aria-pressed="false">
              <span class="layer-name">{layerById.sensory.name}</span>
              <span class="layer-sublabel">({layerById.sensory.sublabel})</span>
            </button>
            <button type="button" class="layer-card card-motor" data-layer-btn data-layer-id="motor" aria-pressed="false">
              <span class="layer-name">{layerById.motor.name}</span>
              <span class="layer-sublabel">({layerById.motor.sublabel})</span>
            </button>
            <button type="button" class="layer-card card-behavior" data-layer-btn data-layer-id="behavior" aria-pressed="false">
              <span class="layer-name">{layerById.behavior.name}</span>
              <span class="layer-sublabel">({layerById.behavior.sublabel})</span>
            </button>
          </div>
        </div>
      </div>

      <aside class="detail-panel">
        <div class="panel-default" data-panel-default>
          <p class="panel-placeholder">Select a layer to explore the adaptation parameters, signals, and research publications.</p>
        </div>
        {
          layers.map((layer) => (
            <div class="panel-content" data-panel-content data-layer-id={layer.id} aria-hidden="true">
              <p class="panel-label">Goal</p>
              <p class="panel-goal">{layer.goal}</p>
              <p class="panel-label">Signals Analyzed</p>
              <div class="panel-badges">{layer.signals.map((s) => <span class="data-badge">{s}</span>)}</div>
              <p class="panel-label">System Adapted</p>
              <div class="panel-badges">{layer.systemAdapted.map((s) => <span class="data-badge">{s}</span>)}</div>
              <p class="panel-label">Key Impact</p>
              <p class="panel-impact">{layer.keyImpact}</p>
              <p class="panel-label">Papers</p>
              <div class="panel-badges panel-papers">{layer.paperIds.map((id) => <span class="paper-badge">{id}</span>)}</div>
            </div>
          ))
        }
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const wrapper = document.querySelector(".research-infographic");
    if (!wrapper) return;

    const layerBtns = wrapper.querySelectorAll("[data-layer-btn]");
    const panelDefault = wrapper.querySelector("[data-panel-default]");
    const panelContents = wrapper.querySelectorAll("[data-panel-content]");
    let activeLayerId = "";

    function setActive(layerId) {
      activeLayerId = layerId;
      wrapper.setAttribute("data-active-layer", layerId || "");

      layerBtns.forEach((btn) => {
        const id = btn.getAttribute("data-layer-id");
        btn.setAttribute("aria-pressed", id === layerId ? "true" : "false");
      });

      if (layerId) {
        panelDefault?.setAttribute("aria-hidden", "true");
        panelContents.forEach((panel) => {
          const id = panel.getAttribute("data-layer-id");
          panel.setAttribute("aria-hidden", id === layerId ? "false" : "true");
        });
      } else {
        panelDefault?.setAttribute("aria-hidden", "false");
        panelContents.forEach((panel) => panel.setAttribute("aria-hidden", "true"));
      }
    }

    layerBtns.forEach((btn) => {
      const layerId = btn.getAttribute("data-layer-id") || "";
      btn.addEventListener("click", () => setActive(activeLayerId === layerId ? "" : layerId));
      btn.addEventListener("mouseenter", () => wrapper.setAttribute("data-hover-layer", layerId));
      btn.addEventListener("mouseleave", () => wrapper.setAttribute("data-hover-layer", ""));
    });

    wrapper.addEventListener("mouseleave", () => {
      wrapper.setAttribute("data-hover-layer", "");
    });
  });
</script>

<style>
  .research-infographic {
    border-radius: 1rem;
    border: 1px dashed rgb(212 212 212);
    background: linear-gradient(180deg, rgb(252 252 252), rgb(248 248 248));
    overflow: hidden;
  }

  .dark .research-infographic {
    border-color: rgb(64 64 64);
    background: linear-gradient(180deg, rgb(30 30 30), rgb(23 23 23));
  }

  .problem-approach .sidebar-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(82 82 82);
  }

  .problem-approach .sidebar-text {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgb(64 64 64);
    margin-top: 0.25rem;
  }

  .dark .problem-approach .sidebar-label {
    color: rgb(163 163 163);
  }

  .dark .problem-approach .sidebar-text {
    color: rgb(212 212 212);
  }

  .research-stage {
    display: grid;
    grid-template-columns: 1fr 0fr;
    transition: grid-template-columns 320ms ease;
    min-height: 360px;
  }

  .diagram-shell {
    padding: 1rem 1rem 1.25rem;
    transition: transform 320ms ease;
  }

  .diagram-canvas {
    position: relative;
    height: 360px;
    max-width: 620px;
    margin: 0 auto;
  }

  .connection-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .cards-grid {
    position: absolute;
    inset: 18px 72px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 112px 140px;
    gap: 26px 16px;
    z-index: 2;
  }

  .card-behavior {
    grid-column: 1 / -1;
  }

  .layer-card {
    border-radius: 0.8rem;
    border: 2px solid rgb(229 229 229);
    background: rgb(255 255 255);
    text-align: left;
    padding: 0.85rem 1rem;
    cursor: pointer;
    transition: transform 280ms ease, box-shadow 280ms ease, opacity 240ms ease, border-color 280ms ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .layer-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.08);
  }

  .layer-name {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgb(23 23 23);
    display: block;
  }

  .layer-sublabel {
    font-size: 0.76rem;
    font-weight: 600;
    color: rgb(82 82 82);
    display: block;
    margin-top: 0.2rem;
  }

  .card-sensory {
    background: linear-gradient(135deg, rgb(255 251 235), rgb(254 243 199));
    border-color: rgb(253 224 71);
  }

  .card-motor {
    background: linear-gradient(135deg, rgb(240 249 255), rgb(224 242 254));
    border-color: rgb(125 211 252);
  }

  .card-behavior {
    background: linear-gradient(135deg, rgb(245 243 255), rgb(237 233 254));
    border-color: rgb(196 181 253);
  }

  .flow-path {
    fill: none;
    stroke-width: 2.25;
    stroke-dasharray: 8 8;
    stroke-linecap: round;
    animation: dash-flow 1.1s linear infinite;
    opacity: 0.26;
    transition: opacity 220ms ease, stroke-width 220ms ease;
  }

  .flow-sensory {
    stroke: rgb(217 119 6);
  }

  .flow-motor {
    stroke: rgb(14 165 233);
  }

  .flow-behavior {
    stroke: rgb(139 92 246);
  }

  .flow-label {
    font-size: 10px;
    font-weight: 700;
    fill: rgb(82 82 82);
    opacity: 0;
    transition: opacity 180ms ease;
    text-anchor: middle;
    pointer-events: none;
  }

  .detail-panel {
    padding: 1rem 1.25rem;
    border-left: 1px solid rgb(229 229 229);
    opacity: 0;
    transform: translateX(14px);
    pointer-events: none;
    transition: opacity 280ms ease, transform 280ms ease;
    overflow: hidden;
  }

  .panel-default[aria-hidden="true"],
  .panel-content[aria-hidden="true"] {
    display: none;
  }

  .panel-placeholder {
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgb(115 115 115);
  }

  .panel-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(115 115 115);
    margin-top: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .panel-goal,
  .panel-impact {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.45;
    color: rgb(23 23 23);
  }

  .panel-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .data-badge {
    font-size: 0.72rem;
    padding: 0.2rem 0.45rem;
    background: rgb(229 229 229);
    border-radius: 0.35rem;
    font-weight: 600;
    color: rgb(64 64 64);
  }

  .paper-badge {
    font-size: 0.7rem;
    padding: 0.18rem 0.4rem;
    background: rgb(255 251 235);
    border: 1px solid rgb(253 224 71);
    border-radius: 0.35rem;
    font-weight: 600;
    color: rgb(120 53 15);
  }

  .research-infographic[data-hover-layer="sensory"] .layer-card:not(.card-sensory),
  .research-infographic[data-hover-layer="motor"] .layer-card:not(.card-motor),
  .research-infographic[data-hover-layer="behavior"] .layer-card:not(.card-behavior) {
    opacity: 0.62;
  }

  .research-infographic[data-active-layer="sensory"] .research-stage,
  .research-infographic[data-active-layer="motor"] .research-stage,
  .research-infographic[data-active-layer="behavior"] .research-stage {
    grid-template-columns: 58% 42%;
  }

  .research-infographic[data-active-layer="sensory"] .diagram-shell,
  .research-infographic[data-active-layer="motor"] .diagram-shell,
  .research-infographic[data-active-layer="behavior"] .diagram-shell {
    transform: translateX(-22px);
  }

  .research-infographic[data-active-layer="sensory"] .detail-panel,
  .research-infographic[data-active-layer="motor"] .detail-panel,
  .research-infographic[data-active-layer="behavior"] .detail-panel {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .research-infographic[data-active-layer="sensory"] .card-sensory,
  .research-infographic[data-active-layer="motor"] .card-motor,
  .research-infographic[data-active-layer="behavior"] .card-behavior {
    transform: scale(1.06);
    border-color: rgb(245 158 11);
    box-shadow: 0 14px 26px rgba(0, 0, 0, 0.14);
    z-index: 3;
  }

  .research-infographic[data-active-layer="sensory"] .connection[data-from="sensory"] .flow-path,
  .research-infographic[data-active-layer="sensory"] .connection[data-to="sensory"] .flow-path,
  .research-infographic[data-active-layer="motor"] .connection[data-from="motor"] .flow-path,
  .research-infographic[data-active-layer="motor"] .connection[data-to="motor"] .flow-path,
  .research-infographic[data-active-layer="behavior"] .connection[data-from="behavior"] .flow-path,
  .research-infographic[data-active-layer="behavior"] .connection[data-to="behavior"] .flow-path {
    opacity: 1;
    stroke-width: 2.7;
  }

  .research-infographic[data-active-layer="sensory"] .connection[data-from="sensory"] .flow-label,
  .research-infographic[data-active-layer="sensory"] .connection[data-to="sensory"] .flow-label,
  .research-infographic[data-active-layer="motor"] .connection[data-from="motor"] .flow-label,
  .research-infographic[data-active-layer="motor"] .connection[data-to="motor"] .flow-label,
  .research-infographic[data-active-layer="behavior"] .connection[data-from="behavior"] .flow-label,
  .research-infographic[data-active-layer="behavior"] .connection[data-to="behavior"] .flow-label {
    opacity: 1;
  }

  .dark .layer-name,
  .dark .panel-goal,
  .dark .panel-impact {
    color: rgb(250 250 250);
  }

  .dark .layer-sublabel,
  .dark .panel-label,
  .dark .panel-placeholder {
    color: rgb(163 163 163);
  }

  .dark .card-sensory {
    background: linear-gradient(135deg, rgb(69 26 3 / 0.3), rgb(120 53 15 / 0.2));
    border-color: rgb(180 83 9);
  }

  .dark .card-motor {
    background: linear-gradient(135deg, rgb(7 89 133 / 0.2), rgb(14 165 233 / 0.15));
    border-color: rgb(56 189 248);
  }

  .dark .card-behavior {
    background: linear-gradient(135deg, rgb(76 29 149 / 0.2), rgb(139 92 246 / 0.15));
    border-color: rgb(167 139 250);
  }

  .dark .detail-panel {
    border-left-color: rgb(64 64 64);
  }

  .dark .data-badge {
    background: rgb(64 64 64);
    color: rgb(212 212 212);
  }

  .dark .paper-badge {
    background: rgb(69 26 3 / 0.4);
    border-color: rgb(180 83 9);
    color: rgb(253 230 138);
  }

  .dark .flow-label {
    fill: rgb(229 229 229);
  }

  @keyframes dash-flow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: 16; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-path {
      animation: none;
    }
  }

  @media (max-width: 1024px) {
    .research-stage {
      grid-template-columns: 1fr;
    }

    .diagram-shell {
      transform: none !important;
    }

    .detail-panel {
      border-left: none;
      border-top: 1px solid rgb(229 229 229);
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }

    .diagram-canvas {
      height: 320px;
    }

    .cards-grid {
      inset: 14px 20px;
      grid-template-rows: 100px 120px;
    }
  }
</style>
