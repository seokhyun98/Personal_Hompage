---
import extras from "../../collections/extras.json";
---

<section id="extras" class="relative z-20 w-full max-w-5xl mx-auto mt-14 px-7 xl:px-0">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">Extra Activities</h2>
  <ul class="mt-4 list-disc space-y-3 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {
      extras.map((item) => (
        <li>
          <strong>{item.title}</strong> - {item.role} ({item.dates})
          <div>{item.description}</div>
        </li>
      ))
    }
  </ul>
</section>
