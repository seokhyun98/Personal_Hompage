---
import about from "../../collections/about.json";
import experiences from "../../collections/experiences.json";
---

<section id="home" class="relative z-20 w-full max-w-5xl mx-auto mt-14 px-7 md:mt-20 lg:mt-24 xl:px-0">
  <div class="grid items-stretch gap-10 md:grid-cols-[3fr_1fr]">
    <div class="min-h-0">
      <h1 class="text-4xl font-bold leading-tight text-neutral-900 md:text-5xl dark:text-white">
        {about.name}
      </h1>
      <p class="mt-3 text-base font-medium text-neutral-700 dark:text-neutral-300">{about.headline}</p>
      <p class="mt-5 text-sm leading-7 text-neutral-700 dark:text-neutral-300 md:text-base">
        Hi there! My name is Seokhyun (Shawn) Hwang, and I am a Ph.D. student in Information Science at the{" "}
        <a href="https://www.washington.edu/" target="_blank" rel="noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">University of Washington</a>
        {" "}in the{" "}
        <a href="https://depts.washington.edu/acelab/" target="_blank" rel="noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">ACE Lab</a>
        {" "}(Advisor:{" "}
        <a href="https://faculty.washington.edu/wobbrock/" target="_blank" rel="noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">Jacob O. Wobbrock</a>). I completed my Master's degree in Intelligent Robotics at{" "}
        <a href="https://www.gist.ac.kr/en/main.html" target="_blank" rel="noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">Gwangju Institute of Science and Technology</a>{" "}
        <a href="https://sites.google.com/view/gist-hcis-lab" target="_blank" rel="noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">HCIS Lab</a>
        {" "}(Advisor:{" "}
        <a href="https://scholar.google.co.kr/citations?user=AjfRd6wAAAAJ&hl" target="_blank" rel="noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">SeungJun Kim</a>). I work on Human-Computer Interaction, VR/AR, haptics, and wearable systems.
      </p>
      <div class="mt-5">
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
          <a
            href={about.cvLink}
            target="_blank"
            rel="noreferrer"
            class="inline-block shrink-0 rounded-md bg-amber-200 px-3 py-2 text-sm font-semibold text-neutral-900 hover:bg-amber-300 dark:bg-amber-900/50 dark:text-amber-100 dark:hover:bg-amber-800/60"
          >
            Latest CV
          </a>
          <span class="text-sm text-neutral-700 dark:text-neutral-300">Contact: {about.email.replace("@", "(at)")}</span>
        </div>
        <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
          {
            about.socialLinks.map((item) => (
              <a
                class="text-sm underline decoration-dotted text-neutral-700 hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-white"
                href={item.url}
                target="_blank"
                rel="noreferrer"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
    <div class="flex h-full min-h-0 md:justify-end">
      <img
        src={about.profileImage}
        alt="Seokhyun Hwang portrait"
        loading="eager"
        decoding="async"
        class="h-full w-full max-w-sm rounded-2xl border border-dashed border-neutral-300 object-cover dark:border-neutral-700"
      />
    </div>
  </div>

  <div class="mt-10 grid items-stretch gap-6 md:grid-cols-[1fr_2fr] md:gap-6">
    <div class="flex min-h-[280px] flex-col">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Education</h3>
      <ul class="mt-3 flex-1 space-y-3">
        {
          about.education.map((item) => (
            <li class="border-l-2 border-amber-300 pl-3 dark:border-amber-600">
              <p class="text-sm font-medium text-neutral-900 dark:text-white">{item.school}</p>
              <p class="text-xs text-neutral-600 dark:text-neutral-400">{item.degree}</p>
              <p class="text-xs text-neutral-500 dark:text-neutral-500">{item.dates}</p>
              {item.advisor && <p class="text-xs italic text-neutral-500 dark:text-neutral-500">Advisor: {item.advisor}</p>}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="experience-card-experiences flex min-h-[280px] flex-col overflow-hidden rounded-xl border border-dashed border-neutral-300 bg-neutral-50 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-900/50">
      <div class="grid min-h-0 flex-1 gap-6 md:grid-cols-2">
        <div class="flex min-h-0 flex-col">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Research Experiences</h3>
          <ul class="experience-list experience-scroll mt-3 min-h-0 flex-1 space-y-2 overflow-y-auto">
            {
              experiences.researchExperience.map((item, i) => (
                <li class={`border-l-2 border-amber-300 pl-3 dark:border-amber-600 ${i >= 4 ? "experience-more-item" : ""}`}>
                  <p class="text-sm font-medium text-neutral-900 dark:text-white">{item.organization}</p>
                  <p class="text-xs text-neutral-600 dark:text-neutral-400">{item.role}</p>
                  <p class="text-xs text-neutral-500 dark:text-neutral-500">{item.dates}</p>
                  {item.detail && <p class="mt-0.5 text-xs italic text-neutral-500 dark:text-neutral-500">{item.detail}</p>}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="flex min-h-0 flex-col">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Teaching Experiences</h3>
          <ul class="experience-list experience-scroll mt-3 min-h-0 flex-1 space-y-2 overflow-y-auto">
            {
              experiences.teachingExperience.map((item, i) => (
                <li class={`border-l-2 border-amber-300 pl-3 dark:border-amber-600 ${i >= 4 ? "experience-more-item" : ""}`}>
                  <p class="text-sm font-medium text-neutral-900 dark:text-white">{item.organization}</p>
                  <p class="text-xs text-neutral-600 dark:text-neutral-400">{item.role}</p>
                  <p class="text-xs text-neutral-500 dark:text-neutral-500">{item.dates}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
      {(experiences.researchExperience.length > 4 || experiences.teachingExperience.length > 4) && (
        <button type="button" class="experience-more-btn mt-2 shrink-0 self-end text-xs font-medium text-neutral-600 underline decoration-dotted hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white" aria-label="Show more">
          More
        </button>
      )}
    </div>
  </div>

  <style>
    .experience-more-item {
      display: none;
    }
    .experience-card-experiences.expanded .experience-more-item {
      display: block;
    }
    .experience-list {
      overflow: hidden;
    }
    .experience-card-experiences.expanded .experience-list {
      overflow-y: auto;
    }
    .experience-scroll {
      scrollbar-width: thin;
      scrollbar-color: rgba(0, 0, 0, 0.25) transparent;
    }
    .dark .experience-scroll {
      scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
    }
    .experience-scroll::-webkit-scrollbar {
      width: 6px;
    }
    .experience-scroll::-webkit-scrollbar-track {
      background: transparent;
    }
    .experience-scroll::-webkit-scrollbar-thumb {
      background: rgba(0, 0, 0, 0.25);
      border-radius: 3px;
    }
    .experience-scroll::-webkit-scrollbar-thumb:hover {
      background: rgba(0, 0, 0, 0.4);
    }
    .dark .experience-scroll::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.3);
    }
    .dark .experience-scroll::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.5);
    }
  </style>

  <script>
    document.querySelectorAll(".experience-more-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const card = btn.closest(".experience-card-experiences");
        const isExpanded = card.classList.toggle("expanded");
        btn.textContent = isExpanded ? "Less" : "More";
      });
    });
  </script>
</section>
