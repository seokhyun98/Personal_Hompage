---
import about from "../../collections/about.json";
---

<section id="about" class="relative z-20 w-full max-w-5xl mx-auto mt-14 px-7 xl:px-0">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">About</h2>

  <h3 class="mt-6 text-xl font-bold text-neutral-900 dark:text-white">Technical Strengths</h3>
  <div class="mt-3 grid gap-5 md:grid-cols-3">
    <article>
      <h4 class="font-semibold text-neutral-900 dark:text-white">Modeling & Designing</h4>
      <ul class="mt-1 list-disc space-y-1 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
        {about.technicalStrengths.modelingAndDesigning.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article>
      <h4 class="font-semibold text-neutral-900 dark:text-white">Software & Tools</h4>
      <ul class="mt-1 list-disc space-y-1 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
        {about.technicalStrengths.softwareAndTools.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article>
      <h4 class="font-semibold text-neutral-900 dark:text-white">Programming Languages</h4>
      <ul class="mt-1 list-disc space-y-1 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
        {about.technicalStrengths.programmingLanguages.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Awards & Honors</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {about.awardsAndHonors.map((item) => <li><strong>{item.title}</strong> ({item.date}){item.detail ? ` - ${item.detail}` : ""}</li>)}
  </ul>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Invited Talks</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {about.invitedTalks.map((item) => <li><strong>{item.organization}</strong> ({item.date}) - {item.detail}</li>)}
  </ul>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Academic Service</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {about.academicService.map((item) => <li>{item}</li>)}
  </ul>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Media Coverage</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 pb-1 text-sm text-neutral-700 dark:text-neutral-300">
    {about.mediaCoverage.map((item) => <li>{item.title} ({item.date})</li>)}
  </ul>
</section>
