---
import about from "../../collections/about.json";
---

<section id="about" class="relative z-20 w-full max-w-5xl mx-auto mt-14 px-7 xl:px-0">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">About</h2>

  <h3 class="mt-6 text-xl font-bold text-neutral-900 dark:text-white">Awards & Honors</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {about.awardsAndHonors.map((item) => <li><strong>{item.title}</strong> ({item.date}){item.detail ? ` - ${item.detail}` : ""}</li>)}
  </ul>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Invited Talks</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {about.invitedTalks.map((item) => <li><strong>{item.organization}</strong> ({item.date}) - {item.detail}</li>)}
  </ul>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Academic Service</h3>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-700 dark:text-neutral-300">
    {about.academicService.map((section) => (
      <li>
        <strong>{section.label}:</strong>
        <ul class="mt-1 list-disc space-y-1 pl-5">
          {section.items.map((item) => <li>{item}</li>)}
        </ul>
      </li>
    ))}
  </ul>

  <h3 class="mt-8 text-xl font-bold text-neutral-900 dark:text-white">Media Coverage</h3>
  <p class="mt-3 rounded-md bg-neutral-100 px-3 py-2 text-sm text-neutral-700 dark:bg-neutral-900 dark:text-neutral-300">
    Articles from Korean outlets are available in Korean.
  </p>
  <ul class="mt-3 list-disc space-y-3 pl-5 pb-1 text-sm text-neutral-700 dark:text-neutral-300">
    {about.mediaCoverage.map((item) => (
      <li>
        <span class="font-medium">"{item.title}"</span> ({item.date})
        <ul class="mt-1 list-disc space-y-0.5 pl-5 text-neutral-600 dark:text-neutral-400">
          <li>
            <span class="font-medium">Outlets:</span>{" "}
            {item.outlets.map((outlet, i) => {
              const o = outlet as { name: string; url?: string };
              return (
                <>
                  {o.url ? (
                    <a href={o.url} target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-neutral-900 dark:hover:text-white">
                      {o.name}
                    </a>
                  ) : (
                    <span>{o.name}</span>
                  )}
                  {i < item.outlets.length - 1 ? "; " : ""}
                </>
              );
            })}
          </li>
        </ul>
      </li>
    ))}
  </ul>
</section>
