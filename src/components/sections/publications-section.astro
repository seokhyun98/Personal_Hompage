---
import publicationsData from "../../collections/publications.json";

function highlightAuthor(authors: string) {
  return authors.split(/(Hwang, S\.\*?)/g).map((part) =>
    part.match(/^Hwang, S\.\*?$/) ? { type: "highlight" as const, text: part } : { type: "text" as const, text: part }
  );
}

const publicationEntries = publicationsData.entries.filter((item) => item.group === "publication");
const conferenceJournalEntries = publicationEntries.filter((e) => e.id.startsWith("c.") || e.id.startsWith("j."));
const posterWorkshopEntries = publicationEntries.filter((e) => e.id.startsWith("w.") || e.id.startsWith("p."));

const filterTags = publicationsData.tagOrder.filter(
  (t) => !["Conference", "Journal", "Poster&Workshop"].includes(t)
);

const patentEntries = publicationsData.entries.filter((item) => item.group === "patent");
const copyrightEntries = publicationsData.entries.filter((item) => item.group === "copyright");
---

<section id="publications" class="relative z-20 w-full max-w-5xl mx-auto mt-14 px-7 xl:px-0">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">Publications</h2>

  <div class="mt-5 flex flex-wrap gap-2">
    <button class="tag-filter-btn active" data-filter="all">Reset_Filter</button>
    {
      filterTags.map((tag) => (
        <button class="tag-filter-btn" data-filter={tag}>
          {tag === "AutomotiveUX" ? "Automotive_UI_UX" : tag}
        </button>
      ))
    }
  </div>

  <h3 class="publication-subheading mt-6 text-sm font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Conferences & Journals</h3>
  <div class="mt-2 publications-list">
    <div class="publications-top-spacer" aria-hidden="true" />
    {
      conferenceJournalEntries.map((entry) => (
        <article class="publication-container rounded-lg border border-dashed border-neutral-300 p-2 dark:border-neutral-700" data-tags={entry.tags.join(" ")}>
          <div class="publication-image">
            {entry.media?.type === "video" ? (
              <video autoplay muted loop playsinline preload="none" poster={entry.media.poster}>
                {entry.media.mp4 && <source src={entry.media.mp4} type="video/mp4" />}
              </video>
            ) : (
              <img src={entry.media?.src} alt={entry.title} loading="lazy" decoding="async" />
            )}
          </div>
          <div class="publication-text">
            <div class="publication-tags">
              {entry.tags.map((tag: string) => <span class="publication-tag" data-tag={tag}>{tag}</span>)}
            </div>
            {entry.link ? (
              <h3 class="mt-1 text-base font-semibold text-neutral-900 dark:text-white">
                <a href={entry.link} target="_blank" rel="noreferrer" class="hover:underline decoration-dotted underline-offset-2">
                  [{entry.id}] {entry.title}
                </a>
              </h3>
            ) : (
              <h3 class="mt-1 text-base font-semibold text-neutral-900 dark:text-white">[{entry.id}] {entry.title}</h3>
            )}
            {entry.award && <p class="mt-1 inline-block rounded-md bg-amber-200 px-2 py-1 text-xs font-semibold text-neutral-900 dark:bg-amber-900/40 dark:text-amber-200">{entry.award}</p>}
            <p class="mt-1 text-sm text-neutral-700 dark:text-neutral-300">
              {highlightAuthor(entry.authors).map((part) =>
                part.type === "highlight" ? (
                  <span class="author-highlight font-semibold text-neutral-900 dark:text-white">{part.text}</span>
                ) : (
                  part.text
                )
              )}
            </p>
            <p class="mt-1 flex flex-wrap items-center gap-2 text-sm text-neutral-700 dark:text-neutral-300">
              <span class="italic">{entry.venue}</span>
              {entry.status === "Accepted" && <span class="publication-status-badge inline-block rounded px-1.5 py-0.5 text-xs font-semibold bg-[#b0c4de] text-[#2c3e50] dark:bg-[#4b5563] dark:text-[#f3f4f6]">Coming Soon</span>}
            </p>
            {entry.status && entry.status !== "Accepted" && <p class="mt-1 text-sm font-medium text-neutral-700 dark:text-neutral-200">({entry.status})</p>}
          </div>
        </article>
      ))
    }
  </div>

  <h3 class="publication-subheading mt-6 text-sm font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Posters & Workshops</h3>
  <div class="mt-2 publications-list">
    <div class="publications-top-spacer" aria-hidden="true" />
    {
      posterWorkshopEntries.map((entry) => (
        <article class="publication-container rounded-lg border border-dashed border-neutral-300 p-2 dark:border-neutral-700" data-tags={entry.tags.join(" ")}>
          <div class="publication-image">
            {entry.media?.type === "video" ? (
              <video autoplay muted loop playsinline preload="none" poster={entry.media.poster}>
                {entry.media.mp4 && <source src={entry.media.mp4} type="video/mp4" />}
              </video>
            ) : (
              <img src={entry.media?.src} alt={entry.title} loading="lazy" decoding="async" />
            )}
          </div>
          <div class="publication-text">
            <div class="publication-tags">
              {entry.tags.map((tag: string) => <span class="publication-tag" data-tag={tag}>{tag}</span>)}
            </div>
            {entry.link ? (
              <h3 class="mt-1 text-base font-semibold text-neutral-900 dark:text-white">
                <a href={entry.link} target="_blank" rel="noreferrer" class="hover:underline decoration-dotted underline-offset-2">
                  [{entry.id}] {entry.title}
                </a>
              </h3>
            ) : (
              <h3 class="mt-1 text-base font-semibold text-neutral-900 dark:text-white">[{entry.id}] {entry.title}</h3>
            )}
            {entry.award && <p class="mt-1 inline-block rounded-md bg-amber-200 px-2 py-1 text-xs font-semibold text-neutral-900 dark:bg-amber-900/40 dark:text-amber-200">{entry.award}</p>}
            <p class="mt-1 text-sm text-neutral-700 dark:text-neutral-300">
              {highlightAuthor(entry.authors).map((part) =>
                part.type === "highlight" ? (
                  <span class="author-highlight font-semibold text-neutral-900 dark:text-white">{part.text}</span>
                ) : (
                  part.text
                )
              )}
            </p>
            <p class="mt-1 flex flex-wrap items-center gap-2 text-sm text-neutral-700 dark:text-neutral-300">
              <span class="italic">{entry.venue}</span>
              {entry.status === "Accepted" && <span class="publication-status-badge inline-block rounded px-1.5 py-0.5 text-xs font-semibold bg-[#b0c4de] text-[#2c3e50] dark:bg-[#4b5563] dark:text-[#f3f4f6]">Coming Soon</span>}
            </p>
            {entry.status && entry.status !== "Accepted" && <p class="mt-1 text-sm font-medium text-neutral-700 dark:text-neutral-200">({entry.status})</p>}
          </div>
        </article>
      ))
    }
  </div>

  <h3 class="publication-subheading mt-6 text-sm font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">Patents & Copyrighted Contents</h3>
  <div class="mt-2 space-y-4">
    {patentEntries.map((entry) => (
      <article>
        <h4 class="text-base font-semibold text-neutral-900 dark:text-white">[{entry.id}] {entry.title}</h4>
        <p class="text-sm text-neutral-700 dark:text-neutral-300">
          {highlightAuthor(entry.authors).map((part) =>
            part.type === "highlight" ? (
              <span class="author-highlight font-semibold text-neutral-900 dark:text-white">{part.text}</span>
            ) : (
              part.text
            )
          )}
        </p>
        <p class="text-sm italic text-neutral-700 dark:text-neutral-300">{entry.venue}</p>
      </article>
    ))}
    {copyrightEntries.map((entry) => (
      <article>
        <h4 class="text-base font-semibold text-neutral-900 dark:text-white">[{entry.id}] {entry.title}</h4>
        <p class="text-sm text-neutral-700 dark:text-neutral-300">
          {highlightAuthor(entry.authors).map((part) =>
            part.type === "highlight" ? (
              <span class="author-highlight font-semibold text-neutral-900 dark:text-white">{part.text}</span>
            ) : (
              part.text
            )
          )}
        </p>
        <p class="text-sm italic text-neutral-700 dark:text-neutral-300">{entry.venue}</p>
      </article>
    ))}
  </div>
</section>

<script is:inline define:vars={{ tagColors: publicationsData.tagColors, tagColorsDark: publicationsData.tagColorsDark }}>
  function applyTagColors() {
    const isDark = document.documentElement.classList.contains("dark");
    const palette = isDark ? (tagColorsDark || tagColors) : tagColors;
    const defaultBg = isDark ? "#374151" : "#f0f0f0";
    const defaultColor = isDark ? "#e5e7eb" : "#444";

    document.querySelectorAll(".publication-tag").forEach((tag) => {
      const key = tag.getAttribute("data-tag");
      tag.style.backgroundColor = palette[key] || defaultBg;
      tag.style.color = isDark ? "#e5e7eb" : "#444";
    });

    document.querySelectorAll(".tag-filter-btn").forEach((btn) => {
      const filter = btn.getAttribute("data-filter");
      btn.style.backgroundColor = palette[filter] || defaultBg;
      btn.style.color = defaultColor;
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll(".tag-filter-btn");
    const publications = document.querySelectorAll(".publication-container");
    const tags = document.querySelectorAll(".publication-tag");
    let currentTagFilter = "all";

    function updateVisibility() {
      publications.forEach((pub) => {
        const tagText = pub.getAttribute("data-tags") || "";
        const hasTag = currentTagFilter === "all" || tagText.split(" ").includes(currentTagFilter);
        pub.classList.toggle("hidden", !hasTag);
      });
    }

    tags.forEach((tag) => { tag.style.fontWeight = "bold"; });
    buttons.forEach((btn) => { btn.style.fontWeight = "bold"; });
    applyTagColors();

    const observer = new MutationObserver(applyTagColors);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

    buttons.forEach((btn) => {
      const filter = btn.getAttribute("data-filter");
      btn.addEventListener("click", () => {
        buttons.forEach((item) => item.classList.remove("active"));
        btn.classList.add("active");
        currentTagFilter = filter || "all";
        updateVisibility();
      });
    });
  });
</script>

<style>
  .publications-list {
    display: flex;
    flex-direction: column;
  }

  .publications-top-spacer {
    flex-shrink: 0;
    height: 0.0rem;
    min-height: 0.0rem;
  }

  .publication-container {
    display: flex;
    align-items: center;
    gap: 16px;
    overflow: hidden;
    max-height: 600px;
    opacity: 1;
    margin-top: 0.75rem;
    transition: opacity 0.3s ease, max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), margin 0.3s ease, padding 0.3s ease, border-width 0.3s ease;
  }

  .publication-container.hidden {
    opacity: 0;
    max-height: 0;
    margin: 0 !important;
    padding: 0 !important;
    border-width: 0 !important;
    pointer-events: none;
  }

  .publication-image {
    flex: 1;
    max-width: 260px;
  }

  .publication-image img,
  .publication-image video {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 8px;
  }

  .publication-text {
    flex: 4;
  }

  .publication-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .publication-tag {
    display: inline-block;
    border-radius: 5px;
    font-size: 12px;
    padding: 2px 6px;
    color: #444;
    transition: background-color 0.2s, color 0.2s;
  }

  .author-highlight {
    background: linear-gradient(transparent 60%, rgba(251, 191, 36, 0.4) 60%);
    padding: 0 1px;
  }

  .dark .author-highlight {
    background: linear-gradient(transparent 60%, rgba(251, 191, 36, 0.35) 60%);
  }

  .publication-status-badge {
    border-radius: 5px;
    font-size: 12px;
    padding: 2px 6px;
    font-weight: 600;
  }

  .tag-filter-btn {
    cursor: pointer;
    border-radius: 6px;
    border: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    font-size: 14px;
    padding: 4px 9px;
    transition: background-color 0.2s, color 0.2s, box-shadow 0.2s;
  }

  .tag-filter-btn.active {
    outline: 2px solid #555;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .dark .tag-filter-btn {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .dark .tag-filter-btn.active {
    outline: 2px solid #9ca3af;
  }

  @media (max-width: 768px) {
    .publication-container {
      flex-direction: column;
      align-items: flex-start;
    }

    .publication-image {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
